      "block_native_models": false,
      "models": [
        {
          "name": "mimo-v2.5",
          "protocol": "openai_chat_completions",
          "tool_strategy": "full_tools"
        }
      ]
    }
  ],
  "tool_fallback": {
    "on_full_tools_failed": "common_plugins_only",
    "allow_no_tools_retry": false,
    "allow_gpt_fallback": false
  }
}
